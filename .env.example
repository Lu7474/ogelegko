# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Оставь пустым для SQLite
# Пример PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/ogelegko
DATABASE_URL=

# Cloudinary
# Оставь пустым для локального хранения media-файлов
# Пример:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# HTTPS
# Включать только на проде, если сайт работает через HTTPS/reverse proxy
HTTPS_ENABLED=False

# Rate-limiting для логина
LOGIN_MAX_ATTEMPTS=5
LOGIN_COOLDOWN_SECONDS=300

# Email-уведомления об ошибках
# Работает только если ADMIN_EMAIL задан и DJANGO_DEBUG=False
ADMIN_EMAIL=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
